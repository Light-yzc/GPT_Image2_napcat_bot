DEBUG=0

# NapCat
NAPCAT_TOKEN=your_napcat_token
NAPCAT_WS_URL=ws://127.0.0.1:3001
BOT_DISPLAY_NAME=AI Bot
WHITELIST=["123456789"]

# Output path
# OUTPUT_DIR is the local directory where generated images are saved.
# NAPCAT_MOUNT_OUTPUT_DIR is the path of the same directory inside the NapCat container.
OUTPUT_DIR=output
NAPCAT_MOUNT_OUTPUT_DIR=/app/output #your mount output dir in napcat docker

# CLIProxyAPI / OpenAI-compatible API
OPENAI_API_KEY=replace-with-your-cli-proxy-api-key
OPENAI_BASE_URL=http://127.0.0.1:8317/v1
RESPONSES_MODEL=gpt-5.4
IMAGE_MODEL=gpt-image-2

# Image generation defaults
IMAGE_QUALITY=high
IMAGE_FORMAT=png
IMAGE_BACKGROUND=opaque
IMAGE_MODERATION=low
DEFAULT_PROMPT=Generate a clean product shot of a glass honey jar on a light background.
